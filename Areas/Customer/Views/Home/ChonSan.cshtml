                            </div>
                        </div>

                        <div class="col-lg-3">
                            <div class="form-group">
                                <label for="timeStart" class="form-label">Thời gian bắt đầu</label>
                                <select id="timeStart" class="form-control">
                                    <option value="05:00">05:00</option>
                                    <option value="06:30">06:30</option>
                                    <option value="08:00">08:00</option>
                                    <option value="14:00">14:00</option>
                                    <option value="15:30">15:30</option>
                                    <option value="17:00">17:00</option>
                                    <option value="18:30">18:30</option>
                                    <option value="20:00">20:00</option>
                                </select>

                            </div>
                        </div>

                        <div class="col-lg-3">
                            <div class="form-group">
                                <label for="timeEnd" class="form-label">Thời gian kết thúc</label>
                                <select id="timeEnd" class="form-control">
                                    <option value="06:30">06:30</option>
                                    <option value="08:00">08:00</option>
                                    <option value="09:30">09:30</option>
                                    <option value="15:30">15:30</option>
                                    <option value="17:00">17:00</option>
                                    <option value="18:30">18:30</option>
                                    <option value="20:00">20:00</option>
                                    <option value="21:30">21:30</option>
                                </select>

                            </div>
                        </div>
                        <div class="col-lg-2" style="margin-top:32px">
                            <button type="button" class="btn btn-outline-warning" id="searchButton">
                                <i class="fa fa-search" aria-hidden="true"></i>
                            </button>
                        </div>
                    </div>

                </form>

            </div>
            <div style="margin:10px"></div>
            <div id="allST"></div>

            <!-- Comment List -->
            <div class="mb-5">
                <h2 class="mb-4">@danhgia.Count Comments</h2>
