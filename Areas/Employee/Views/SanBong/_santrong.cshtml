@model IEnumerable<QLSanBong.Models.Santrong>
@{
    int count = 1;
    List<int> dsNVDonHang = ViewBag.NVDonHangCn as List<int>;
}
<div class="container">
<table class="table table-hover table-bordered">
    <thead>
        <tr>
            <th>STT</th>
            <th>Mã sân bóng</th>
            <th>Ngày đặt sân</th>
            <th>Giờ bắt đầu</th>
            <th>Giờ kết thúc</th>
            <th>Trạng thái</th>
            <th></th>
           <!--Thêm các cột khác tại đây-->
        </tr>
    </thead>
    <tbody>
        @foreach (var sb in Model)
        {
            <tr>
                <td>@count</td>
                <td>@sb.MaSb</td>
                <td>@String.Format("{0:dd/MM/yyyy}", sb.Ngaydatsan)</td>
                <td>@sb.Giobatdau</td>
                <td>@sb.Gioketthuc</td>
                <td>Trống</td>
                    <td>
                        
                        @if (dsNVDonHang != null && dsNVDonHang.Contains(2))
                        {
                            <button class="btn btn-success open-modal"
                                data-bs-toggle="modal"
                                data-bs-target="#modalOrder"
                                data-masan="@sb.MaSb"
                                data-ngaydatsan="@sb.Ngaydatsan"
                                data-magio="@sb.Magio"
                                data-giobatdau="@sb.Giobatdau"
                                data-gioketthuc="@sb.Gioketthuc" id="order" name="order">
                            <i class="fas fa-calendar-alt"></i> Đặt sân
                            </button>
                        }
                        else
                        {
                        }
                    </td>


                <!--Thêm các cột khác tại đây-->
            </tr>
count++;
            }
            
    </tbody>
</table>
</div>


