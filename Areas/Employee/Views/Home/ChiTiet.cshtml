@model QLSanBong.Models.NhanVien

@{
    ViewData["Title"] = "ChiTiet";
    Layout = "~/Areas/Employee/Views/Shared/_NVLayOut.cshtml";
}



<div class="container">
    <h2>CHI TIẾT NHÂN VIÊN</h2>
    <hr />
    <div>
        <dl class="dl-horizontal">
            <dt>
                Tên nhân viên
            </dt>

            <dd>
                @Model.TenNv
            </dd>

            <dt>
                Số điện thoại
            </dt>

            <dd>
                @Model.Sdt
            </dd>

            <dt>
                Giới tính
            </dt>

            <dd>
                @Model.Gioitinh
            </dd>

            <dt>
                Chức vụ
            </dt>

            <dd>
                @Model.Chucvu
            </dd>

            <dt>
                Tên đăng nhập
            </dt>

            <dd>
                @Model.Tendangnhap
            </dd>
        </dl>
    </div>
</div>
