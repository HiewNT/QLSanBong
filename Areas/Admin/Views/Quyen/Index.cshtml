@model IEnumerable<QLSanBong.Models.Quyen>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayOut.cshtml";
    int count = 1;
}

<h2>Index</h2>

<p>
    <a asp-action="Create">Create New</a>
</p>
<div class="container">
    <table class="table table-bordered table-hover">
        <thead>
            <tr>
                <th>STT</th>
                <th>
                    Tên quyền
                </th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@(count++)</td>
                    <td>
                        @item.TenQuyen
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.MaQuyen">Edit</a> |
                        <a asp-action="Details" asp-route-id="@item.MaQuyen">Details</a> |
                        <a asp-action="Delete" asp-route-id="@item.MaQuyen">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
