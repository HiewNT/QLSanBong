    <script>
        $(document).ready(function () {
            // Lưu trạng thái tab hiện tại
            $('#AdminTab').on('shown.bs.tab', function (e) {
                localStorage.setItem('activeTab', 'Admin');
            });

            $('#menu1Tab').on('shown.bs.tab', function (e) {
                localStorage.setItem('activeTab', 'menu1');
            });
            $('#menu2Tab').on('shown.bs.tab', function (e) {
                localStorage.setItem('activeTab', 'menu2');
            });

            // Lưu trạng thái tab hiện tại cho trang menu1
            $('#menu3Tab').on('shown.bs.tab', function (e) {
                localStorage.setItem('activeTab', 'menu3');
            });

            $('#menu4Tab').on('shown.bs.tab', function (e) {
                localStorage.setItem('activeTab', 'menu4');
            });
            if (!activeTab || (activeTab !== 'Admin' && activeTab !== 'menu1' && activeTab !== 'menu4' && activeTab !== 'menu2' && activeTab !== 'menu3')) {
                activeTab = 'Admin';
            }

            // Lấy trạng thái từ localStorage
            var activeTab = localStorage.getItem('activeTab') || 'Admin';



            if (activeTab) {
                $('a[href="#' + activeTab + '"]').tab('show');
            }

        });
    </script>
    <script>
        function changePageall(pageNumber) {
            // Lấy giá trị từ các trường input
            var Name = $("#name").val();
            var Phone = $("#phone").val();
            var DateDat = $("#datedat").val();

            // Gửi yêu cầu tìm kiếm và chuyển trang đến server
            $.ajax({
                url: '@Url.Action("Index", "DatSan")',
                type: 'GET',
                data: {
                    name: Name,
                    phone: Phone,
                    datedat: DateDat,
                    page: pageNumber
                },
                success: function (res) {

                    // Cập nhật URL với các tham số tìm kiếm
                    var newUrl = window.location.pathname + '?name=' + encodeURIComponent(Name) +
                        '&phone=' + encodeURIComponent(Phone) +
                        '&datedat=' + encodeURIComponent(DateDat) +
                        '&pageall=' + pageNumber;

                    // Thay đổi URL trình duyệt mà không làm tải lại trang
                    window.history.replaceState({}, '', newUrl);
                    window.location.reload();
                },
                error: function () {
                    console.log('Error');
                }
            });
        }
    </script>
