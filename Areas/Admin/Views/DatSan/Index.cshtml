                        <div class="form-group mr-4">
                            <label for="name">Nhập tên khách hàng</label>
                            @Html.TextBox("name", null, new { @class = "form-control" })
                        </div>
                        <div class="form-group mr-4">
                            <label for="phone">Nhập số điện thoại</label>
                            @Html.TextBox("phone", null, new { @class = "form-control" })
                        </div>
                        <div class="form-group mr-4">
                            <label for="datedat">Thời gian đặt sân</label>
                            @Html.TextBox("datedat", null, new { @class = "form-control", type = "date" })
                        </div>
                        <div class="form-group mr-4">
                            <label for="datesd">Ngày sử dụng sân</label>
                            @Html.TextBox("datesd", null, new { @class = "form-control", type = "date" })
                        </div>
                        <div style="margin-top:30px">
                            <button type="submit" class="btn btn-primary ml-2">
                                <i class="fas fa-search"></i>
                            </button>
                        </div>
                    }

                    <ul class="nav nav-tabs" role="tablist">
                        <li class=" nav-item active"><a id="AdminTab" class="nav-link" data-toggle="tab" href="#Admin">Tất cả yêu cầu(@ViewBag.totalItemCountall)</a></li>
                        <li class="nav-item"><a id="menu1Tab" class="nav-link" data-toggle="tab" href="#menu1">Chờ xác nhận (@ViewBag.totalItemCountcho)</a></li>
                        <li class="nav-item"><a id="menu2Tab" class="nav-link" data-toggle="tab" href="#menu2">Đã xác nhận (@ViewBag.totalItemCountxn)</a></li>
                        <li class="nav-item"><a id="menu4Tab" class="nav-link" data-toggle="tab" href="#menu4">Đã hoàn thành (@ViewBag.totalItemCountht)</a></li>
                        <li class="nav-item"><a id="menu3Tab" class="nav-link" data-toggle="tab" href="#menu3">Đã hủy (@ViewBag.totalItemCounthuy)</a></li>
