@model QLSanBong.Models.SanBong
@using QLSanBong.Models;

@{
    ViewBag.Title = "CapNhat";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayOut.cshtml";
}

<div class="container">
    <div>
        <h3 class="align-center">CẬP NHẬT THÔNG TIN SÂN BÓNG</h3>
        <hr />
        <div style="margin-top:20px"></div>
    </div>

    @using (Html.BeginForm("CapNhat", "SanBong", FormMethod.Post, new { enctype = "multipart/form-data" }))
    {
        @Html.AntiForgeryToken()

        <div class="form-horizontal" style="display:flex;">
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })
            <div class="container">
            <div class="form-group">
                <label class="control-label col-md-8">MÃ SÂN BÓNG</label>
                <div class="col-md-8">
                    @Html.TextBoxFor(model => model.MaSb, new { @readonly = "readonly" })
                </div>
                </div>
                <div class="form-group">
                    <label class="control-label col-md-8">DIỆN TÍCH</label>
                    <div class="col-md-8">
                        @Html.EditorFor(model => model.Dientich, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.Dientich, "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="form-group">
                    <label class="control-label col-md-8">TRẠNG THÁI</label>
                    <div class="col-md-8">
                        @Html.EditorFor(model => model.Trangthai, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.Trangthai, "", new { @class = "text-danger" })
                    </div>
                </div>

            </div>
            <div class="container">
                <div class="form-group">
                    <label class="control-label col-md-8">TÊN SÂN BÓNG</label>
                    <div class="col-md-24">
                        @Html.EditorFor(model => model.TenSb, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.TenSb, "", new { @class = "text-danger" })
                    </div>
                </div>
                <div class="form-group">
                    <label class="control-label col-md-8">HÌNH ẢNH</label>
                    <div class="col-md-8">
                        <input type="file" name="fileAnh" />
                        @Html.ValidationMessageFor(model => model.Hinhanh, "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="form-group">
                    <label class="control-label col-md-8">GHI CHÚ</label>
                    <div class="col-md-12">
                        @Html.TextAreaFor(model => model.Ghichu, new { @class = "form-control", rows = 7 }) <!-- Adjust rows as needed -->
                    @Html.ValidationMessageFor(model => model.Ghichu, "", new { @class = "text-danger" })
                    </div>
                </div>

            </div>
        </div>
            <div style="margin:10px"></div>
            <div class="form-group">
                <div class="col-md-offset-2 col-md-4">
                    <input class="btn btn-success" type="submit" value="CẬP NHẬT" />
                </div>
            </div>
            <div style="margin:10px"></div>
            <div class="col-md-offset-2 col-md-4">
                <a href="@Url.Action("Index","SanBong")" class="btn btn-outline-info">
                    Trở về
                </a>
            </div>
    }
</div>
