@model IEnumerable<QLSanBong.Models.GiaGioThue>

@{
    int count = 1;
}

<div class="row">
    <div class="col-md-8"></div>
    <div class="col-md-4">
        <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#addBGModal">
            <i class="fa fa-user-plus"></i>
            Thêm khung giờ mới
        </button>
    </div>
</div>
<div class="container" style="margin:20px">
    <table class="table table-hover table-bordered">
        <thead>
            <tr>
                <th>
                    STT
                </th>
                <th>
                    Mã giờ
                </th>
                <th>
                   Thời gian bắt đầu
                </th>
                <th>
                    Thời gian kết thúc
                </th>
                <th>
                   Đơn giá (VND)
                </th>

            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @count
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Magio)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Giobatdau)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Gioketthuc)
                    </td>
                    <td>
                        @string.Format("{0:N0}", item.Dongia)
                    </td>

                    <td>
                        <button class="btn btn-success" name="edit" data-mag="@item.Magio"><i class="fas fa-edit"></i></button>
                        <button class="btn btn-danger" name="delete" data-mag="@item.Magio"><i class="fas fa-trash"></i></button>
                    </td>

                </tr>
                count++;
            }
        </tbody>
    </table>
</div>