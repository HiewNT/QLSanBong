@section scripts{
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script type="text/javascript">
        $(document).ready(function () {
            $('#khunggia').load('/Login/Khunggia');
        });
        $(document).ready(function () {
            $('#allSB').load('/Login/AllSB');
        });
        $(document).ready(function () {
            // Ẩn #allST ban đầu
            $('#allST').hide();

            // Xử lý sự kiện khi click vào nút "Tìm sân trống"
            $('#searchButton').click(function () {
                //var searchCriteria = {
                //    idSan : $('#idSan').val();
                //    loai : $('#loai').val();
                //    dayOrder: $('#dayOrder').val(),
                //    timeStart: $('#timeStart').val(),
                //    timeEnd: $('#timeEnd').val()
                //};
                //loadAllST(searchCriteria);
                $('#allST').show();
                handleTimeChange();
                var idSan = $('#idSan').val();
                var loai = $('#loai').val();
                var dayOrder = $('#dayOrder').val();
                var timeStart = $('#timeStart').val();
                var timeEnd = $('#timeEnd').val();
                $.get('/Login/AllST', { idSan: idSan, loai: loai, dayOrder: dayOrder, timeStart: timeStart, timeEnd: timeEnd }, function (data) {
                    $('#allST').html(data);
                });
            });
        });
        function loadAllST(searchCriteria) {
            $('#allST').show();
            handleTimeChange();
            $.get('/Login/AllST', searchCriteria, function (data) {
                $('#allST').html(data);
            });
        }
        // Lấy phần tử select cho timeStart và timeEnd
        const timeStartSelect = document.getElementById("timeStart");
        const timeEndSelect = document.getElementById("timeEnd");

            initialTimeStartValue = timeStartSelect.value;
            initialTimeEndValue = timeEndSelect.value;
        // Hàm xử lý thay đổi thời gian
        function handleTimeChange() {
            // Lấy giá trị timeStart và timeEnd từ các select
            const timeStartValue = timeStartSelect.value;
            const timeEndValue = timeEndSelect.value;

            // Chuyển đổi giá trị thành số để so sánh
            const startTime = parseInt(timeStartValue.replace(":", ""));
            const endTime = parseInt(timeEndValue.replace(":", ""));

            // Kiểm tra điều kiện
            if (startTime >= endTime) {
                alert("Thời gian bắt đầu phải trước thời gian kết thúc.");

                timeStartSelect.value = initialTimeStartValue;
                timeEndSelect.value = initialTimeEndValue;
                // Thực hiện xử lý khi điều kiện không đúng (nếu cần)
            } else {
                initialTimeStartValue = timeStartSelect.value;
                initialTimeEndValue = timeEndSelect.value;
            }
        }

        document.addEventListener("DOMContentLoaded", function () {
            // Lấy phần tử input có ID là "dayOrder"
            const dayOrderInput = document.getElementById("dayOrder");

            // Kiểm tra xem dayOrderInput có tồn tại và có giá trị là null không
            if (dayOrderInput && dayOrderInput.value === "") {
                // Nếu dayOrderInput tồn tại và giá trị là null (trống)
                // Đặt giá trị của nó thành ngày hiện tại
                const currentDate = new Date();
                const year = currentDate.getFullYear();
                const month = (currentDate.getMonth() + 1).toString().padStart(2, "0");
                const day = currentDate.getDate().toString().padStart(2, "0");
                const formattedDate = `${year}-${month}-${day}`;

                // Gán giá trị cho dayOrderInput
                dayOrderInput.value = formattedDate;
            }
        });
        // Khi nút "Sign up" được nhấn
        $("#themKH1").on("click", function () {
            // Đóng modalLogin
            $("#modalOrder").modal("hide");
            // Mở addKHModal
            $("#addKHModal").modal("show");
        }); $("#themKH2").on("click", function () {
            // Đóng modalLogin
            $("#modalLogin").modal("hide");
            // Mở addKHModal
            $("#addKHModal").modal("show");
        });

        $(document).on('click', "button[name='order']", function () {
            var maSan = this.getAttribute('data-ma-san');
            var ngayDatSan = this.getAttribute('data-ngay-dat-san');
            var gioBatDau = this.getAttribute('data-gio-bat-dau');
            var gioKetThuc = this.getAttribute('data-gio-ket-thuc');

            // Chuyển đổi giá trị ngày từ datetime sang date
            var ngayDatSanDate = new Date(ngayDatSan);
            var ngayDatSanFormatted = formatDate(ngayDatSanDate);
            magiods = this.getAttribute('data-ma-gio');
            $('#idstadium').val(maSan);
            $('#day').val(ngayDatSanFormatted);
            $('#start').val(gioBatDau);
            $('#end').val(gioKetThuc);
        });
        // Sự kiện khi modal bị ẩn (đóng)
        $('#modalOrder').on('hidden.bs.modal', function (e) {
            // Đặt giá trị của các trường "userName" và "phoneNumber" về chuỗi rỗng
            $('#name').val("");
            $('#phoneNumber').val("");
        });

        // Hàm để định dạng ngày thành "yyyy-MM-dd" (định dạng của trường date)
        function formatDate(date) {
            var day = date.getDate();
            var month = date.getMonth() + 1;
            var year = date.getFullYear();

            // Đảm bảo hiển thị "0" trước ngày và tháng nếu cần
            if (day < 10) {
                day = "0" + day;
            }
            if (month < 10) {
                month = "0" + month;
            }

            return year + "-" + month + "-" + day;
        }
        </script>
        <script>

        $('#addKH').click(function () {
            let tenkh = $('#tenkh').val();
            let gtkh = $('#gtkh').val();
            let dckh = $('#dckh').val();
            let sdtkh = $('#sdtkh').val();
            let userkh = $('#userkh').val();
            let passkh = $('#passkh').val();

            // thêm ràng buộc dữ liệu
            if (tenkh.length == 0 || sdtkh.length == 0) {
                alert("Vui lòng nhập đầy đủ dữ liệu");
                return;
            }

            // dùng ajax
            $.ajax({
                url: '/Login/DangKy',
                type: 'POST',
                data: {
                    tenkh: tenkh,
                    gtkh: gtkh,
                    dckh: dckh,
                    sdtkh: sdtkh,
                    userkh: userkh,
                    passkh: passkh,
                },
                success: function (data) {
                    if (data.code == 200) {
                        alert("Đăng ký khách hàng mới thành công");
                        $('#addKHModal').modal('hide');
                        $('#modalLogin').modal('show');
                    } else {
                        alert(data.mgs);

                        $('#addKHModal').modal('show');
                    }
                }
            });
        });

        $('#addKHModal').on('hidden.bs.modal', function () {
            // Xóa giá trị của các ô input khi modal được đóng
            $('#tenkh').val('');
            $('#dckh').val('');
            $('#sdtkh').val('');
            $('#userkh').val('');
            $('#passkh').val('');

        });
        var magiods;
        let lastSearch = {}
        $('#addYC').click(function () {
            let name = $('#name').val();
            let phoneNumber = $('#phoneNumber').val();
            let day = $('#day').val();
            let start = $('#start').val();
            let end = $('#end').val();
            let magio = magiods;
            let idstadium = $('#idstadium').val();
            let pttt = $('#pttt').val();
            // thêm ràng buộc dữ liệu
            if (name.length == 0 || phoneNumber.length == 0) {
                alert("Vui lòng nhập đầy đủ dữ liệu");
                return;
            }

            lastSearch = {
                dayOrder: $('#dayOrder').val(),
                timeStart: $('#timeStart').val(),
                timeEnd: $('#timeEnd').val(),
                idSan: $('#idSan').val(),
                loai: $('#loai').val(),
            };

            // dùng ajax
            $.ajax({
                url: '/Login/ThemMoi',
                type: 'POST',
                data: {
                    name: name,
                    day: day,
                    start: start,
                    end: end,
                    magio: magio,
                    phoneNumber: phoneNumber,
                    idstadium: idstadium,
                    trangthai: 'Đang chờ',
                    pttt: pttt,
                },
                success: function (data) {
                    if (data.code == 200) {
                        alert("Yêu cầu đặt sân thành công");
                        $('#modalOrder').modal('hide');
                        loadAllST(lastSearch);
                    } else {
                        alert(data.msg);
                    }
                }
            });
        });
        document.addEventListener("DOMContentLoaded", function () {
            var loginModal = document.querySelector("#modalLogin");
            var usernameInput = document.querySelector("#userName");
            var passwordInput = document.querySelector("#password");

            loginModal.addEventListener("hidden.bs.modal", function () {
                // Xóa giá trị trường nhập liệu khi modal đóng
                usernameInput.value = "";
                passwordInput.value = "";
            });
        });
        </script>
