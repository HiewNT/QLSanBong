                                                  <a href="javascript:void(0)" class="btn btn-primary px-4 mx-auto mb-4" data-masan="${item.maSb}" onclick="fillIdSan(this)">Tìm kiếm sân trống</a>
                                    </div>
                                </div>
                            `;

                        itemsContainer.insertAdjacentHTML('beforeend', itemHtml);
                    }

                    itemsToShow += 3; // Tăng số lượng đối tượng đã hiển thị
                }
            });
        });
        function fillIdSan(element) {
            const masan = element.getAttribute("data-masan");
            const loaisan = element.getAttribute("data-loaisan");
            document.getElementById("loai").value = loaisan;
            document.getElementById("idSan").value = masan;
            $('html, body').animate({
                scrollTop: $('#orderstadium').offset().top
            }, 1000);
        }
    </script>
    <script>
        $(document).ready(function () {
            // Xử lý sự kiện khi click vào nút trong danh sách portfolio-filters
            $('#portfolio-flters li').on('click', function () {
                $('#portfolio-flters li').removeClass('active');
                $(this).addClass('active');

                var filterValue = $(this).attr('data-filter');

                // Ẩn tất cả các mục portfolio-item
                $('.portfolio-item').hide();

                // Hiển thị các mục tương ứng với filterValue
                if (filterValue === '*') {
                    $('.portfolio-item').show();
                } else {
                    $('.portfolio-item' + filterValue).show();
                }
            });
        });
    </script><script>
