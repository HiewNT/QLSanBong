@model IEnumerable<QLSanBong.Models.GiaGioThue>
@{
    int count = 1;
}

<div class="container">
    <table class="table table-hover table-bordered">
        <thead>
            <tr>
                <th>STT</th>
                <th>Giờ bắt đầu</th>
                <th>Giờ kết thúc</th>
                <th>Đơn giá (VND) </th>
                <!--Thêm các cột khác tại đây-->
            </tr>
        </thead>
        <tbody>
            @foreach (var sb in Model)
            {
                <tr>
                    <td>@count</td>
                    <td>@sb.Giobatdau</td>
                    <td>@sb.Gioketthuc</td>

                    <td>
                        @string.Format("{0:N0}", sb.Dongia)
                    </td>


                    <!--Thêm các cột khác tại đây-->
                </tr>
                count++;
            }

        </tbody>
    </table>
</div>
