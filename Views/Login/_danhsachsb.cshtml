@model IEnumerable<QLSanBong.Models.SanBong>

<div class="text-center">
    <h2 class="section-heading text-uppercase">Danh sách các sân bóng</h2>
    <h3 class="section-subheading text-muted">Lựa chọn hàng đầu</h3>
</div>
<div class="container">
    <div class="row" style="justify-content:center">
        @foreach (var item in Model)
        {
            <div class="col-sm-12 col-md-6 col-lg-4">
                <div class="card">
                    <a class="portfolio-link" data-bs-toggle="modal" href="#stadiummodal" style="text-align:center;text-decoration:none">
                        <img src="@item.Hinhanh" style="height:160px; width:223.59px" />

                        <span style=" color:blue;font-size:medium">
                        @item.TenSb
                        </span>
                    </a>
                </div>
            </div>
        }
    </div>
</div>

<!-- stadium Modals-->
<div class="portfolio-modal modal fade" id="stadiummodal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="container">
                aaaaaaaaaaaaaaaa
            </div>
        </div>
    </div>
</div>